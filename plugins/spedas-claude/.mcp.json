{
  "mcpServers": {
    "spedas": {
      "command": "uvx",
      "args": [
        "--with",
        "mcp>=1.26.0,<2",
        "--from",
        "git+https://github.com/spedas/spedas_agent_kit.git@main",
        "spedas-agent-kit"
      ],
      "env": {
        "XHELIO_CDAWEB_CACHE_DIR": "${HOME}/.cache/spedas-agent-kit/cdaweb",
        "PDSMCP_CACHE_DIR": "${HOME}/.cache/spedas-agent-kit/pds",
        "XHELIO_SPICE_KERNEL_DIR": "${HOME}/.cache/spedas-agent-kit/spice-kernels"
      }
    }
  }
}
